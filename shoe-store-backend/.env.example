# Server
PORT=5000
NODE_ENV=development

# JWT (JWT_EXPIRE in seconds: 604800 = 7 days)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=604800

# CORS
FRONTEND_URL=http://localhost:3000

# Database
# SQLite database file will be created automatically at: db/shoestore.db
DATABASE_URL=sqlite:///./db/shoestore.db
